{
  "enableAllProjectMcpServers": true,
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "cat \"${CLAUDE_PROJECT_DIR}/.claude/bootstrap.md\""
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(curl:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git status:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(uv run ruff:*)",
      "Bash(uv run mypy:*)",
      "Bash(uv run pytest:*)",
      "Bash(uv run pre-commit:*)",
      "Bash(uv run python:*)",
      "Bash(uv sync:*)",
      "Bash(python3:*)",
      "Read",
      "Edit",
      "Write",
      "WebSearch",
      "WebFetch",
      "Glob",
      "Grep",
      "mcp__qwen-tools__review_snippet",
      "mcp__qwen-tools__review_design"
    ],
    "ask": [
      "Bash(rm:*)",
      "Bash(git reset:*)",
      "Bash(git checkout:*)"
    ]
  }
}